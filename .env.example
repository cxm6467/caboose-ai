# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_OWNER=your_github_username_or_org
GITHUB_REPO=your_repository_name

# Cron Configuration
# Update schedule in cron format (default: every day at 2 AM)
UPDATE_SCHEDULE=0 2 * * *

# Documentation Sources (comma-separated URLs)
DOC_SOURCES=https://docs.anthropic.com/claude/docs,https://docs.cursor.com

# Rules Configuration
RULES_FILE_PATHS=.cursorrules,CLAUDE.md,.claude/CLAUDE.md
DEFAULT_BRANCH=main
